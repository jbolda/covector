{
  "name": "covector-workspace",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "repository": "https://github.com/jbolda/covector.git",
  "author": "Jacob Bolda <me@jacobbolda.com>",
  "license": "Apache-2.0",
  "scripts": {
    "covector": "node --conditions=development ./packages/covector/bin/covector.mjs",
    "build": "npm run build --workspaces --if-present",
    "build:action": "npm run build:action -w action",
    "run:action:source": "npm run run:source -w action",
    "run:action:built": "npm run run:built -w action",
    "test": "vitest",
    "test:types": "tsc --noEmit -p tsconfig.tests.json",
    "pretty": "prettier --write --ignore-path .gitignore \"!packages/action/dist/index.js\" \"packages/**/*.{js,ts}\" \"__fixtures__/**/*.{json,js,ts,yml,yaml}\""
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@effectionx/vitest": "^0.3.1",
    "@types/node": "^24",
    "effection": "^4.0.3",
    "fixturez": "^1.1.0",
    "prettier": "^3.4.2",
    "rolldown-plugin-wasm": "^0.3.2",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  }
}
