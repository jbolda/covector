{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "strict": true,
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "target": "es6",
    "pretty": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "checkJs": false,
    "preserveSymlinks": true,
    "skipLibCheck": true,
    "declaration": true,
    "forceConsistentCasingInFileNames": true
  }
}
